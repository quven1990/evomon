{
  "name": "evomon",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prebuild": "tsx scripts/generate-static-files.ts",
    "predev": "tsx scripts/generate-static-files.ts",
    "build": "next build",
    "dev": "next dev",
    "lint": "eslint",
    "images:sync": "node scripts/download-pet-images.mjs",
    "images:compress": "node scripts/compress-images.mjs",
    "images:prepare": "npm run images:sync && npm run images:compress",
    "deploy": "npm run build && wrangler pages deploy out --project-name=evomon --commit-dirty=true && npm run purge-cache",
    "purge-cache": "node scripts/purge-cloudflare-cache.mjs",
    "pages:dev": "wrangler pages dev out"
  },
  "dependencies": {
    "geist": "^1.7.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.20.3",
    "typescript": "^5",
    "wrangler": "^4.106.0"
  }
}
